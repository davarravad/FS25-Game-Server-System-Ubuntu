APP_NAME=FSG FS25 Node
APP_ENV=production
APP_URL=http://localhost:8080
APP_KEY=change-this-app-key
SESSION_SECRET=change-this-session-secret
NODE_NAME=FS25 Local Node
NODE_SLUG=fs25-local-node
NODE_API_TOKEN=change-this-node-api-token

DB_HOST=db
DB_PORT=3306
DB_NAME=fsg_panel
DB_USER=fsg_panel
DB_PASSWORD=change-this-db-password
DB_ROOT_PASSWORD=change-this-root-password

ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=ChangeMeNow!

# Used only to bootstrap the first managed host in the website database.
DEFAULT_HOST_NAME=Local Agent
AGENT_URL=http://agent:8081
AGENT_SHARED_TOKEN=change-this-agent-token
SHARED_GAME_PATH=/opt/fs25/game
SHARED_DLC_PATH=/opt/fs25/dlc
SHARED_INSTALLER_PATH=/opt/fs25/installer

PANEL_PORT=8080
INSTANCE_BASE_PATH=/opt/fsg-panel/instances
BACKUP_BASE_PATH=/opt/fsg-panel/backups
ADMIN_SFTP_PORT=22220
ADMIN_SFTP_USERNAME=paneladmin
ADMIN_SFTP_PASSWORD=change-this-sftp-password

TZ=America/New_York
